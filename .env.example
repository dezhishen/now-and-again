# ─── Now & Again 后端配置模板 ─────────────────────────────────────
# 复制此文件为 .env 并根据需要修改

# ── 服务端口 ──────────────────────────────────────────────────────
# 后端 HTTP 监听端口
PORT=8080

# ── 安全 ──────────────────────────────────────────────────────────
# JWT 签名密钥（可选）
# 未设置时自动生成随机密钥并持久化到 $DATA_DIR/.jwt_secret
# 生产环境建议手动设置以保证重启后不变:
# 生成建议: openssl rand -hex 64
# JWT_SECRET=

# 首次运行时自动创建的默认管理员密码（仅未初始化时生效）
# 未设置则随机生成并打印到控制台
ADMIN_DEFAULT_PASSWORD=admin123

# ── 数据库 ────────────────────────────────────────────────────────
# 数据库驱动: sqlite | postgres
DB_DRIVER=sqlite

# PostgreSQL 连接串（仅 DB_DRIVER=postgres 时需要）
# 格式: host=localhost user=postgres password=xxx dbname=now_and_again port=5432 sslmode=disable
# DB_DSN=host=localhost user=postgres password=xxx dbname=now_and_again port=5432 sslmode=disable

# ── 数据目录 ──────────────────────────────────────────────────────
# 所有持久化数据的根目录，包含数据库文件和上传文件
#   $DATA_DIR/now-and-again.db    数据库文件
#   $DATA_DIR/uploads/            上传文件
#   $DATA_DIR/logs/              日志文件
DATA_DIR=./data

# ── 运行模式 ──────────────────────────────────────────────────────
# Gin 框架模式: debug | release | test
# debug:   详细日志 + 请求日志
# release: 仅错误日志，生产环境推荐
GIN_MODE=debug
