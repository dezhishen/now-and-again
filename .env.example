# ─── Now & Again 后端配置模板 ─────────────────────────────────────
# 复制此文件为 .env 并根据需要修改

# ── 服务端口 ──────────────────────────────────────────────────────
# 后端 HTTP 监听端口
PORT=8080

# ── 安全 ──────────────────────────────────────────────────────────
# JWT 签名密钥（生产环境必须修改为随机字符串！）
# 生成建议: openssl rand -base64 64
JWT_SECRET=change-me-in-production

# 首次运行时自动创建的默认管理员密码（仅未初始化时生效）
# 未设置则随机生成并打印到控制台
ADMIN_DEFAULT_PASSWORD=admin123

# ── 数据库 ────────────────────────────────────────────────────────
# 数据库驱动: sqlite | postgres
DB_DRIVER=sqlite

# SQLite: 文件路径（如 now-and-again.db）
# PostgreSQL: host=localhost user=postgres password=xxx dbname=now_and_again port=5432 sslmode=disable
DB_DSN=now-and-again.db

# ── 数据目录 ──────────────────────────────────────────────────────
# 如果设置了 DATA_DIR，会自动将数据库和上传文件放在该目录下:
#   $DATA_DIR/now-and-again.db    数据库文件
#   $DATA_DIR/uploads/            上传文件
# 注意: 设置 DATA_DIR 后，DB_DSN 和 UPLOAD_DIR 会被自动覆盖
# DATA_DIR=./data

# ── 上传文件 ──────────────────────────────────────────────────────
# 上传文件存储目录（DATA_DIR 未设置时生效）
UPLOAD_DIR=./uploads

# ── 运行模式 ──────────────────────────────────────────────────────
# Gin 框架模式: debug | release | test
# debug:   详细日志 + 请求日志
# release: 仅错误日志，生产环境推荐
GIN_MODE=debug
