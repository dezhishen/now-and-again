# CI Dockerfile for CLI — copies pre-built binary (built by GitHub Actions)
ARG TARGETARCH

FROM registry.alpinelinux.org/img/alpine:3.24
ARG TARGETARCH
RUN apk add --no-cache ca-certificates tzdata
RUN addgroup -S appgroup && adduser -S appuser -G appgroup
ENV TZ=Asia/Shanghai

COPY dist/na-${TARGETARCH} /usr/local/bin/na
RUN chmod +x /usr/local/bin/na

USER appuser
ENTRYPOINT ["/usr/local/bin/na"]
